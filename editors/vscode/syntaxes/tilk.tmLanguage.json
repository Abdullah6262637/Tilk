{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "T캅LK",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#control" },
    { "include": "#operators" },
    { "include": "#builtins" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tilk",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tilk",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tilk",
              "match": "\\\\[nrt\"\\\\]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tilk",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tilk",
          "match": "\\b(ise|se|de휓ilse|iken|dek|artarak|azalarak|olduk챌a|olunca|i힊lev|d철nd체r|hata_ise|hata_f캇rlat|hata_firlat|tamamlan캇nca|tamamland캇휓캇nda|dahil_et)\\b"
        }
      ]
    },
    "control": {
      "patterns": [
        {
          "name": "keyword.operator.logical.tilk",
          "match": "\\b(ve|veya|de휓il)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.tilk",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.tilk",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.tilk",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.tilk",
          "match": "\\b(yazd캇r|boyut|ekle|k철k|karekok|체s|ust|mutlak|힊imdi|simdi|uyku|dosya_oku|dosya_yaz|dosya_sil|arkaplanda_챌al캇힊t캇r|arkaplanda_calistir|kanal)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.tilk",
          "match": "\\b([a-zA-Z챌휓캇i힊철체횉휒I캅힇횜횥_][a-zA-Z0-9챌휓캇i힊철체횉휒I캅힇횜횥_]*)\\s*(?=\\()"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.tilk",
          "match": "\\b(do휓ru|yanl캇힊|bo힊)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.tilk",
          "match": "\\b[a-zA-Z챌휓캇i힊철체횉휒I캅힇횜횥_][a-zA-Z0-9챌휓캇i힊철체횉휒I캅힇횜횥_]*\\b"
        }
      ]
    }
  },
  "scopeName": "source.tilk"
}
