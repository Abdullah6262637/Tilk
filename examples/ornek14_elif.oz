// zincirleme değilse ise (elif) testi
sayi = 15;

sayi < 10 ise {
    yazdır("sayı 10'dan küçük");
} değilse sayi < 20 ise {
    yazdır("sayı 10 ile 20 arasında");
} değilse sayi < 30 ise {
    yazdır("sayı 20 ile 30 arasında");
} değilse {
    yazdır("sayı 30 veya daha büyük");
}

sayi2 = 42;

sayi2 == 0 ise {
    yazdır("sıfır");
} değilse sayi2 == 42 ise {
    yazdır("kırk iki");
} değilse {
    yazdır("diğer");
}
