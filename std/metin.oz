// Standart Metin Modülü

işlev uzunluk(m) {
    döndür uzunluk(m);
}

işlev parcala(m, ayrac) {
    döndür böl(m, ayrac);
}

işlev icerir(m, aranan) {
    döndür içerir(m, aranan);
}

işlev buyuk_harf(m) {
    döndür büyük_harf(m);
}

işlev kucuk_harf(m) {
    döndür küçük_harf(m);
}

işlev kirp(m) {
    döndür kırp(m);
}

işlev sayiya_cevir(m) {
    döndür sayıya_çevir(m);
}
